{
  "name": "kindred-mobile-app",
  "version": "0.1.0",
  "description": "Kindred Mobile Web App - A mobile-first social dating application built with Nuxt 4 and Vue 3.",
  "private": true,
  "type": "module",
  "scripts": {
    "update-api": "./scripts/update-api.sh",
    "build": "nuxt build",
    "dev": "tmux new-session -As kindred-mobile-app -c . 'nuxt dev --port 5102 --host'",
    "generate": "nuxt generate",
    "preview": "nuxt preview --port 5102",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.7.1",
    "@pinia/nuxt": "^0.11.3",
    "@ts-rest/core": "^3.52.1",
    "@vite-pwa/nuxt": "^1.1.1",
    "nuxt": "4.4.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "openapi-zod-client": "^1.18.3",
    "ts-to-zod": "^5.1.0"
  }
}
